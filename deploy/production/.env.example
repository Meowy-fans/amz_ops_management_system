# Copy to /data/docker-compose/amz-listing-management-system/.env and fill real values.
# Do not commit real secrets.

APP_MODE=server
LOG_LEVEL=INFO

DATABASE_NAME=amz_listing
DATABASE_USER=amz_listing
DATABASE_PASSWORD=change-me-before-production

GIGA_BASE_URL=https://api.gigacloudlogistics.com
GIGA_CLIENT_ID=change-me
GIGA_CLIENT_SECRET=change-me

LLM_SERVICE_MODE=direct
LLM_PROVIDER=qwen
DASHSCOPE_API_KEY=change-me
DEEPSEEK_API_KEY=change-me

# Amazon listing issue monitoring. Keep dry-run until the repair queue is reviewed.
LISTING_ISSUE_SCHEDULER_ENABLED=false
LISTING_ISSUE_SYNC_INTERVAL_SECONDS=3600
LISTING_ISSUE_SYNC_LIMIT=
LISTING_ISSUE_INCLUDE_SUPPRESSED_REPORT=true
LISTING_ISSUE_REPAIR_DRY_RUN=true
LISTING_QUALITY_REQUIRE_IMAGE_REVIEW=false

# Feishu alerts (daily-check, weekly-report, Amazon order sync)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/change-me

# Amazon order sync (Phase A: read orders + Feishu notify humans)
AMAZON_ORDER_SYNC_NOTIFY=true
AMAZON_ORDER_SYNC_LOOKBACK_HOURS=48
AMAZON_ORDER_SYNC_STATUSES=Unshipped,PartiallyShipped
# Optional sidecar loop interval (scripts/sync_amazon_orders_loop.sh)
AMAZON_ORDER_SYNC_INTERVAL_SECONDS=1800
AMAZON_ORDER_SYNC_INITIAL_DELAY_SECONDS=120
AMAZON_ORDER_SYNC_FAILURE_ALERT_THRESHOLD=3

# Amazon order daily report (Beijing 09:00 by default)
AMAZON_ORDER_DAILY_REPORT_NOTIFY=true
AMAZON_ORDER_DAILY_REPORT_HOURS=24
AMAZON_ORDER_DAILY_REPORT_HOUR=9
AMAZON_ORDER_DAILY_REPORT_MINUTE=0
AMAZON_ORDER_DAILY_REPORT_TZ=Asia/Shanghai
