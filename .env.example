

# 阿里云RDS配置
DATABASE_HOST=rmXXXXXom
DATABASE_PORT=5xx2
DATABASE_NAME=exxxe
DATABASE_USER=mxxr
DATABASE_PASSWORD=dxxxxxx


# 应用配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
APP_ENV=development


# Giga API配置
GIGA_BASE_URL=https://xxxxcom
GIGA_CLIENT_ID=6xxxxe
GIGA_CLIENT_SECRET=9xxxxxx

# Amazon SP-API配置（生产建议拆到 .env.amazon-sp-api）
AMAZON_LWA_CLIENT_ID=
AMAZON_LWA_CLIENT_SECRET=
AMAZON_REFRESH_TOKEN=
AMAZON_SELLER_ID=
AMAZON_MARKETPLACE_ID=ATVPDKIKX0DER
AMAZON_SP_API_ENDPOINT=https://sellingpartnerapi-na.amazon.com
AMAZON_REGION=NA
AMAZON_HTTPS_PROXY=
AMAZON_EXPECTED_EGRESS_IP=

# ============================================
# LLM服务配置
# ============================================
# 服务模式: direct(直接调用) | agent(未来通过Agent)
LLM_SERVICE_MODE=direct

# LLM提供商选择: deepseek | qwen
LLM_PROVIDER=qwen

# DeepSeek配置
DEEPSEEK_API_KEY=sk-xxxxxb
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_ENDPOINT=https://api.deepseek.com/v1

# 千问配置
DASHSCOPE_API_KEY=sk-6xxxxxx1
QWEN_MODEL=qwen-plus
AUTOGEN_BASE_URL=http://localhost:8000
AUTOGEN_TIMEOUT_SECONDS=300
AUTOGEN_GLOBAL_MAX_ROUNDS=1
AUTOGEN_TERMINATION_KEYWORD=TERMINATE
AUTOGEN_FALLBACK_MODEL=deepseek-chat

APP_MODE=server
IO_SERVER_HOST=0.0.0.0
IO_SERVER_PORT=8080
APP_TASK=
LISTING_CATEGORY=
INPUT_FILE_PATH=
AUTO_CONFIRM=false

# Amazon listing issue monitoring
LISTING_ISSUE_SCHEDULER_ENABLED=false
LISTING_ISSUE_SYNC_INTERVAL_SECONDS=3600
LISTING_ISSUE_SYNC_LIMIT=
LISTING_ISSUE_INCLUDE_SUPPRESSED_REPORT=true
LISTING_ISSUE_REPAIR_DRY_RUN=true
LISTING_QUALITY_REQUIRE_IMAGE_REVIEW=false

# Feishu webhook for operational alerts
FEISHU_WEBHOOK_URL=

# Amazon order sync
AMAZON_ORDER_SYNC_NOTIFY=true
AMAZON_ORDER_SYNC_LOOKBACK_HOURS=48
AMAZON_ORDER_SYNC_STATUSES=Unshipped,PartiallyShipped
AMAZON_ORDER_SYNC_INTERVAL_SECONDS=1800
AMAZON_ORDER_SYNC_INITIAL_DELAY_SECONDS=120
AMAZON_ORDER_SYNC_FAILURE_ALERT_THRESHOLD=3

# Amazon order daily report (Beijing 09:00 by default)
AMAZON_ORDER_DAILY_REPORT_NOTIFY=true
AMAZON_ORDER_DAILY_REPORT_HOURS=24
AMAZON_ORDER_DAILY_REPORT_HOUR=9
AMAZON_ORDER_DAILY_REPORT_MINUTE=0
AMAZON_ORDER_DAILY_REPORT_TZ=Asia/Shanghai
